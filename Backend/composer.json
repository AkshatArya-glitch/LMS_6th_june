{
  "name": "emancipation/lms-backend",
  "description": "Emancipation LMS Backend API",
  "type": "project",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^11.0",
    "firebase/php-jwt": "^6.8",
    "symfony/var-dumper": "^6.0",
    "mpdf/mpdf": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "laravel/tinker": "^2.8"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ],
    "post-install-cmd": [],
    "post-update-cmd": []
  }
}
